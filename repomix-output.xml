                {children}
                {/* Heart Icon */}
                <button
                    className="absolute top-3 left-3 p-2 md:hover:scale-110 transition-transform z-10"
                    onClick={(e) => {
                        e.preventDefault();
                        e.stopPropagation();
                        setIsFavorite(!isFavorite);
