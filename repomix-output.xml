RETURNS BOOLEAN AS $$
BEGIN
  RETURN (
    SELECT email = 'fatemaabdulhamed13@gmail.com'
    FROM auth.users
    WHERE id = auth.uid()
  );
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

