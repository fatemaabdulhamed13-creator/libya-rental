                        <h1 className="font-bold text-lg">{booking.property.title}</h1>
                        <p className="text-sm text-muted-foreground">
                            محادثة مع {otherUser?.full_name || "المستخدم"}
                        </p>
                    </div>
                    <div className="text-sm text-muted-foreground">
